############################################
# 🚀 SPRING BOOT / JAVA / MAVEN
############################################
HELP.md
target/
!.mvn/wrapper/maven-wrapper.jar

# Keep target inside src if needed
!**/src/main/**/target/
!**/src/test/**/target/

############################################
# 🧠 LOG FILES
############################################
logs/
*.log
*.out

############################################
# 🔐 ENV / SECRETS (VERY IMPORTANT)
############################################
.env
.env.*
application-local.yml
application-dev.yml

# Never push secrets
*.key
*.pem
*.p12

############################################
# 🗄️ DATABASE FILES (LOCAL ONLY)
############################################
*.db
*.sqlite
*.h2.db

############################################
# 🐳 DOCKER
############################################
docker-compose.override.yml

############################################
# 🖥️ OS GENERATED FILES
############################################
.DS_Store
Thumbs.db

############################################
# 🧰 STS (Spring Tool Suite)
############################################
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

############################################
# 💡 IntelliJ IDEA
############################################
.idea/
*.iws
*.iml
*.ipr

############################################
# 🧱 NetBeans
############################################
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

############################################
# 💻 VS CODE
############################################
.vscode/

############################################
# 🌐 NODE (IF ANGULAR/FRONTEND INSIDE)
############################################
node_modules/
dist/
.angular/
coverage/

############################################
