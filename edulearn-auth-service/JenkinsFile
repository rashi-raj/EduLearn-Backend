pipeline {
    agent any

    tools {
        jdk 'JDK17'
        maven 'Maven3'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'edulearn-backend',
                url: 'https://github.com/rashi-raj/EduLearn-Backend.git'
            }
        }

        stage('Build') {
            steps {
                dir('edulearn-auth-service') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Test') {
            steps {
                dir('edulearn-auth-service') {
                    sh 'mvn test'
                }
            }
        }
    }
}